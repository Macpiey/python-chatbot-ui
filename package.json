{
  "name": "Commodities AI",
  "productName": "Commodities AI",
  "version": "2.0.3",
  "description": "AI Chat Application",
  "main": "src/index.js",
  "scripts": {
    "start": "electron-forge start",
    "start:dev": "cross-env NODE_ENV=development electron-forge start",
    "build": "webpack --config webpack.config.js",
    "build:prod": "cross-env NODE_ENV=production webpack --config webpack.config.js",
    "dev": "webpack --config webpack.config.js --watch",
    "package": "npm run build:prod && electron-forge package",
    "make": "npm run build:prod && electron-forge make",
    "make:win": "npm run build:prod && electron-forge make --platform win32",
    "make:mac": "npm run build:prod && electron-forge make --platform darwin",
    "publish": "npm run build:prod && electron-forge publish",
    "lint": "echo \"No linting configured\"",
    "setup:win": "node scripts/build-windows-installer.js",
    "setup:win:inno": "npm run package:optimized && node scripts/build-inno-installer.js",
    "setup:win:inno:quick": "node scripts/build-inno-installer.js",
    "setup:mac": "node scripts/build-dmg-installer.js",
    "package:optimized": "npm run build:prod && electron-forge package",
    "build:setup": "npm run package && npm run setup:win && npm run setup:mac",
    "setup:assets": "node scripts/setup-assets.js",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js --patch",
    "release:minor": "node scripts/release.js --minor",
    "release:major": "node scripts/release.js --major"
  },
  "keywords": [],
  "author": {
    "name": "Kalya Labs",
    "email": ""
  },
  "license": "MIT",
  "dependencies": {
    "aws-amplify": "^6.0.18",
    "chart.js": "^4.4.9",
    "electron-squirrel-startup": "^1.0.1",
    "jwt-decode": "^4.0.0",
    "react": "^19.1.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.4",
    "recharts-to-png": "^3.0.1",
    "remark-gfm": "^4.0.1",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@babel/preset-env": "^7.27.1",
    "@babel/preset-react": "^7.27.1",
    "@electron-forge/cli": "^7.8.0",
    "@electron-forge/maker-deb": "^7.8.0",
    "@electron-forge/maker-dmg": "^7.8.0",
    "@electron-forge/maker-rpm": "^7.8.0",
    "@electron-forge/maker-squirrel": "^7.8.0",
    "@electron-forge/maker-zip": "^7.8.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.0",
    "@electron-forge/plugin-fuses": "^7.8.0",
    "@electron/fuses": "^1.8.0",
    "babel-loader": "^10.0.0",
    "core-js": "^3.43.0",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "electron": "36.1.0",
    "electron-installer-dmg": "^4.0.0",
    "electron-notarize": "^1.2.2",
    "style-loader": "^4.0.0",
    "webpack": "^5.99.7",
    "webpack-cli": "^6.0.1"
  }
}
